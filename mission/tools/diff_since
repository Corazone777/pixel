#!/bin/bash
# Show git diff since a reference point
REF="${1:-HEAD~1}"
cd /home/mission
git add -A 2>/dev/null
echo "=== Changed files ==="
git diff --cached "$REF" --stat 2>/dev/null || git diff --stat 2>/dev/null
echo ""
echo "=== Diff ==="
git diff --cached "$REF" 2>/dev/null | head -300 || git diff 2>/dev/null | head -300
